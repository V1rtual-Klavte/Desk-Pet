{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "糖糖桌宠",
  "version": "0.1.0",
  "identifier": "com.deskpet.tangtang",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "配信中",
        "url": "index.html",
        "width": 400,
        "height": 200,
        "minWidth": 700,
        "minHeight": 400,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "shadow": false,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
  }
}