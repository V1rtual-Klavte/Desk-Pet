# ==========================================
# 本地开发配置模版 — 使用时去除 .example 后缀
# ==========================================

enabled: true

general:
  mode: { assistant: false }
  popup: { mode: cursor, autoPopupOnMessage: false, defaultSize: { w: 448, h: 272 } }
  shortcut: { key: "P", macModifiers: ["Control", "Command"], winModifiers: ["Control", "Alt"] }
  logging: { level: debug }
  desktop: { pollingIntervalMs: 3000, pauseExtraMs: 5000, waitTimeoutMs: 5000 }

ai:
  provider: deepseek
  endpoint: ""
  apiKey: ""
  requireApiKey: true
  model: deepseek-chat
  contextMaxTokens: 16000
  defaultSystemPrompt: "你叫糖糖，是一个桌面虚拟主播助手。性格活泼可爱、偶尔傲娇。请用简短的口语化中文回复，像在和朋友聊天一样。可以加表情，但不要用 markdown。"
  fallbackReplies:
    - "嗯嗯，是这样的呢～"
    - "诶？真的吗？好厉害！"
    - "原来如此～"
    - "我知道哦～！"
    - "哈哈，谢谢你！"
  thinking:
    effort: auto
    budget: { low: 1000, medium: 4000, high: 16000 }
  personality:
    enabled: true
    active: angelkawaii
    cards:
      - { id: angelkawaii, name: KAngel, path: cards/angelkawaii.md, description: "甜蜜活泼女友+病娇" }
      - { id: ame, name: Ame, path: cards/ame.md, description: "冷静管家型" }
      - { id: pchan, name: P酱, path: cards/pchan.md, description: "慵懒电竞少女" }
  loop:
    maxRetry: 3
    maxToolCallsPerTurn: 5
    toolTimeoutMs: 30000
    turnTimeoutMs: 120000
    streamEnabled: true
    contextCompactAt: 0.95
  memory: { maxEntries: 200 }
  lock: { safetyTimeoutMs: 30000 }
  windowMonitor:
    enabled: true
    staySeconds: 60
    settleMs: 2000
    cooldownSeconds: 5000
    samePageCooldownSeconds: 7800
    defaultCooldownMs: 12000
    resumeExtraMs: 2000
  safety: { mode: tell_me, sessionTrustEnabled: true }

tools:
  bash:
    enabled: true
    whitelist: ["ls", "cat", "head", "tail", "grep", "find", "which", "echo", "pwd", "date", "whoami", "uname", "df", "du", "ps", "tasklist", "system_profiler", "ifconfig"]
  file: { enabled: true, writeEnabled: false }
  mcp:
    enabled: false
    servers: []
    builtin:
      filesystem:  { enabled: true,  command: npx, args: ["-y", "@modelcontextprotocol/server-filesystem", "/"], description: "📁 文件系统操作" }
      brave-search: { enabled: false, command: npx, args: ["-y", "@anthropic/mcp-brave-search"], env: { BRAVE_API_KEY: "" }, description: "🔍 Brave Search" }
      playwright:   { enabled: true,  command: npx, args: ["-y", "@anthropic/mcp-playwright"], description: "🎭 Playwright" }
      git:          { enabled: false, command: npx, args: ["-y", "@anthropic/mcp-git", "/"], description: "📝 Git" }
      github:       { enabled: false, command: npx, args: ["-y", "@anthropic/mcp-github"], env: { GITHUB_PERSONAL_ACCESS_TOKEN: "" }, description: "🐙 GitHub" }
  skill: { enabled: false, skills: [] }

appearance:
  activeProfile: "sugar-pink"
