# ==========================================
# 本地开发配置（不入 git）模版 — 使用时去除 .example 后缀
# enabled: true  → 使用此文件全部配置
# enabled: false → 回退到 CONFIG.yaml
# 与 CONFIG.yaml 结构完全一致，本地调参改这个就行
# ==========================================

enabled: true #是否启用dev配置，false则回退到 CONFIG.yaml

# ── 模式 ──
mode:
  assistant: false              # 助手模式开关（默认轻量模式）

# ── AI 接口 ──
ai:
  provider: deepseek # deepseek | openai | ollama | custom
  endpoint:
  apiKey: "" # 留空则读环境变量 VITE_API_KEY
  model: deepseek-chat
  contextMaxTokens: 16000     # 上下文窗口上限 (tokens)
  thinkingEffort: "auto"       # auto | low | medium | high — 思考强度
  thinkingBudget:
    low: 1000
    medium: 4000
    high: 16000

  # 默认人格（无角色卡时的回退 system prompt）
  defaultSystemPrompt: "你叫糖糖，是一个在直播的虚拟主播。性格活泼可爱、偶尔傲娇。请用简短的口语化中文回复，像在和朋友聊天一样。可以加表情，但不要用 markdown。"

  # 离线 fallback 语录（未配置 API Key 时随机回复）
  fallbackReplies:
    - "嗯嗯，是这样的呢～"
    - "诶？真的吗？好厉害！"
    - "原来如此～"
    - "我知道哦～！"
    - "哈哈，谢谢你！"
    - "原来是这个样子啊～"
    - "不是吧！？这也太夸张了"
    - "对对对！"
    - "你这么说我好开心～"
    - "欸——这样啊，好有趣！"

# ── 人格系统 ──
personality:
  enabled: true                # 是否启用人格系统（false=使用默认人格）
  active: "angelkawaii"        # 当前激活的人格 ID（空字符串=不使用任何人格卡）
  cards:                       # 可用人格卡列表
    - id: angelkawaii
      name: KAngel
      path: cards/angelkawaii.md
      description: 甜蜜活泼女友 + 深层病娇
    - id: ame
      name: Ame
      path: cards/ame.md
      description: 冷静严肃管家型 AI
    - id: pchan
      name: P酱
      path: cards/pchan.md
      description: 慵懒电竞少女

# ── 窗口监控 ──
windowMonitor:
  enabled: true
  staySeconds: 60 # 用户在同一窗口停留多久后触发（秒）
  settleMs: 2000 # 窗口切换防抖（毫秒）
  cooldownSeconds: 5000 # 全局冷却时长（秒）
  samePageCooldownSeconds: 7800 # 同页面不重复触发冷却（秒）
  defaultCooldownMs: 12000 # 默认冷却毫秒数
  resumeExtraMs: 2000 # resume_monitor 额外延迟（毫秒）

# ── AI 并发锁 ──
aiLock:
  safetyTimeoutMs: 30000 # 生成锁安全超时（30s 后强制解锁）

# ── 长期记忆 ──
memory:
  maxEntries: 200 # 最大记忆条数

# ── 系统通知（已移除）──
# macOS 未签名构建下无法实现，代码中留有注释占位。
# 若后续有新方案可重新启用。

# ── 桌面后端（Rust 轮询）──
desktop:
  pollingIntervalMs: 3000 # 窗口标题轮询间隔（毫秒）
  pauseExtraMs: 5000 # 暂停时额外安全时间（毫秒）
  waitTimeoutMs: 5000 # 暂停等待超时（毫秒）

# ── 快捷键 ──
shortcut:
  key: "P"                      # 快捷键字符
  macModifiers: ["Control", "Command"]  # macOS 修饰键
  winModifiers: ["Control", "Alt"]      # Windows 修饰键

# ── 用户界面（运行时可通过设置面板修改，自动保存到本地存储）──
user:
  popupMode: cursor            # cursor | fixed
  popupSize: { w: 448, h: 272 }
  shortcutKey: "P"
  shortcutMacModifiers: ["Control", "Command"]
  shortcutWinModifiers: ["Control", "Alt"]
  autoPopupOnMessage: false      # 收到新消息时自动弹出窗口

# ── 日志 ──
logging:
  level: debug # debug | info | warn | error

# ── 核心 Loop ──
loop:
  maxRetry: 3
  maxToolCallsPerTurn: 5
  toolTimeoutMs: 30000
  turnTimeoutMs: 120000
  streamEnabled: true
  contextCompactAt: 0.95

# ── 工具系统 ──
tools:
  bash:
    enabled: true
    whitelist: ["ls", "cat", "head", "tail", "grep", "find", "which",
                "echo", "pwd", "date", "whoami", "uname", "df", "du",
                "ps", "tasklist", "system_profiler", "ifconfig"]
  file:
    enabled: true
    writeEnabled: false        # 轻量模式强制 false
  mcp:
    enabled: false             # 助手模式才有效
    servers: []
  skill:
    enabled: false             # 助手模式才有效

# ── 安全 ──
safety:
  mode: "tell_me"              # just_do_it | tell_me | let_me_tk
  sessionTrustEnabled: true
